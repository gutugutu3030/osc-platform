{
  "name": "osc-adapter-webui-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build:webui": "esbuild src/webui/main.ts --bundle --platform=browser --format=esm --target=es2020 --outfile=../build/generated/frontend/assets/webui/webui.js",
    "build:editor": "esbuild src/editor/main.ts --bundle --platform=browser --format=esm --target=es2020 --outfile=../build/generated/frontend/assets/editor/editor.js",
    "build": "npm run build:webui && npm run build:editor",
    "typecheck": "tsc --project tsconfig.json",
    "test:ui": "vitest run --environment jsdom"
  },
  "devDependencies": {
    "esbuild": "^0.25.3",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}